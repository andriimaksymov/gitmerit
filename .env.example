# Backend Configuration
PORT=3001
NODE_ENV=development

# GitHub API
GITHUB_API_TOKEN=github_token_placeholder
GITHUB_API_BASE_URL=https://api.github.com

# CORS (Frontend URL)
FRONTEND_URL=http://localhost:5173

# Gemini AI
GEMINI_API_KEY=gemini_key_placeholder

# Future: OpenAI Integration
OPENAI_API_KEY=openai_key_placeholder

# AI Provider Orchestration
AI_PROVIDER_ORDER=openai,gemini,groq
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=openai/gpt-oss-120b

# Future: Database
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_analyzer
